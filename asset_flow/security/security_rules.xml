<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Asset Allocation Rules -->
        <record id="rule_assetflow_allocation_employee" model="ir.rule">
            <field name="name">Employee Allocation Rule</field>
            <field name="model_id" ref="model_assetflow_allocation"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        </record>

        <record id="rule_assetflow_allocation_dept_head" model="ir.rule">
            <field name="name">Department Head Allocation Rule</field>
            <field name="model_id" ref="model_assetflow_allocation"/>
            <field name="domain_force">['|', ('department_id.manager_id.user_id', '=', user.id), ('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_assetflow_dept_head'))]"/>
        </record>

        <record id="rule_assetflow_allocation_manager" model="ir.rule">
            <field name="name">Manager Allocation Rule</field>
            <field name="model_id" ref="model_assetflow_allocation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        </record>

        <!-- Asset Transfer Rules -->
        <record id="rule_assetflow_transfer_employee" model="ir.rule">
            <field name="name">Employee Transfer Rule</field>
            <field name="model_id" ref="model_assetflow_transfer"/>
            <field name="domain_force">['|', ('source_holder_id.user_id', '=', user.id), ('target_holder_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        </record>

        <record id="rule_assetflow_transfer_dept_head" model="ir.rule">
            <field name="name">Department Head Transfer Rule</field>
            <field name="model_id" ref="model_assetflow_transfer"/>
            <field name="domain_force">['|', '|', ('source_holder_id.department_id.manager_id.user_id', '=', user.id), ('target_holder_id.department_id.manager_id.user_id', '=', user.id), '|', ('source_holder_id.user_id', '=', user.id), ('target_holder_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_assetflow_dept_head'))]"/>
        </record>

        <record id="rule_assetflow_transfer_manager" model="ir.rule">
            <field name="name">Manager Transfer Rule</field>
            <field name="model_id" ref="model_assetflow_transfer"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        </record>

        <!-- Resource Booking Rules -->
        <record id="rule_assetflow_booking_employee" model="ir.rule">
            <field name="name">Employee Booking Rule</field>
            <field name="model_id" ref="model_assetflow_booking"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        </record>

        <record id="rule_assetflow_booking_manager" model="ir.rule">
            <field name="name">Manager Booking Rule</field>
            <field name="model_id" ref="model_assetflow_booking"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        </record>

        <!-- Maintenance Rules -->
        <record id="rule_assetflow_maintenance_employee" model="ir.rule">
            <field name="name">Employee Maintenance Rule</field>
            <field name="model_id" ref="model_assetflow_maintenance"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
        </record>

        <record id="rule_assetflow_maintenance_manager" model="ir.rule">
            <field name="name">Manager Maintenance Rule</field>
            <field name="model_id" ref="model_assetflow_maintenance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_assetflow_manager'))]"/>
        </record>
    </data>
</odoo>
