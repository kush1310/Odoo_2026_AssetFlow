<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Asset Maintenance Kanban View -->
    <record id="view_assetflow_maintenance_kanban" model="ir.ui.view">
        <field name="name">assetflow.maintenance.kanban</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" quick_create="false">
                <field name="id"/>
                <field name="name"/>
                <field name="asset_id"/>
                <field name="priority"/>
                <field name="technician_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title font-weight-bold">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="text-muted small">
                                    Asset: <field name="asset_id"/>
                                </div>
                                <div class="text-muted small" t-if="record.technician_id.raw_value">
                                    Technician: <field name="technician_id"/>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="priority" widget="priority"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="state" widget="label_selection" options="{'classes': {'pending': 'default', 'approved': 'info', 'assigned': 'warning', 'progress': 'primary', 'resolved': 'success', 'rejected': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Asset Maintenance Tree View -->
    <record id="view_assetflow_maintenance_tree" model="ir.ui.view">
        <field name="name">assetflow.maintenance.tree</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <tree string="Maintenance Requests" decoration-danger="priority == '2'" decoration-warning="priority == '1'" decoration-muted="state in ['resolved', 'rejected']">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="priority" widget="priority"/>
                <field name="technician_id"/>
                <field name="state" widget="badge" decoration-info="state == 'approved'" decoration-warning="state == 'assigned'" decoration-primary="state == 'progress'" decoration-success="state == 'resolved'"/>
            </tree>
        </field>
    </record>

    <!-- Asset Maintenance Form View -->
    <record id="view_assetflow_maintenance_form" model="ir.ui.view">
        <field name="name">assetflow.maintenance.form</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <form string="Asset Maintenance Request">
                <header>
                    <button name="action_approve" string="Approve Request" type="object" class="oe_highlight" groups="asset_flow.group_assetflow_manager" invisible="state != 'pending'"/>
                    <button name="action_assign" string="Assign Ticket" type="object" class="oe_highlight" groups="asset_flow.group_assetflow_manager" invisible="state != 'approved'"/>
                    <button name="action_start" string="Start Work" type="object" class="oe_highlight" invisible="state != 'assigned'"/>
                    <button name="action_resolve" string="Resolve Ticket" type="object" class="oe_highlight" invisible="state != 'progress'"/>
                    <button name="action_reject" string="Reject Ticket" type="object" class="btn-danger" groups="asset_flow.group_assetflow_manager" invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,approved,assigned,progress,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Issue Summary"/>
                        <h1>
                            <field name="name" placeholder="e.g. Broken Laptop Screen" readonly="state in ['resolved', 'rejected']"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="asset_id" options="{'no_create': True}" readonly="state in ['resolved', 'rejected']"/>
                            <field name="priority" widget="priority" readonly="state in ['resolved', 'rejected']"/>
                        </group>
                        <group>
                            <field name="technician_id" options="{'no_create': True}" readonly="state in ['resolved', 'rejected']"/>
                        </group>
                    </group>
                    <group>
                        <group string="Issue Description">
                            <field name="description" nolabel="1" placeholder="Describe the failure, steps leading to it..." readonly="state in ['resolved', 'rejected']"/>
                        </group>
                        <group string="Visual Proof / Photo">
                            <field name="photo" widget="image" nolabel="1" readonly="state in ['resolved', 'rejected']"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_assetflow_maintenance_all" model="ir.actions.act_window">
        <field name="name">Maintenance Board</field>
        <field name="res_model">assetflow.maintenance</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Raise your first asset maintenance request.
            </p>
            <p>
                Report hardware issues, route them through management approval, and track repairs through the Kanban pipeline.
            </p>
        </field>
    </record>
</odoo>
