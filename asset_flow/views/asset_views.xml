<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Asset Category Views -->
    <record id="view_assetflow_category_tree" model="ir.ui.view">
        <field name="name">assetflow.category.tree</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <tree string="Asset Categories" decoration-muted="status == 'inactive'">
                <field name="name"/>
                <field name="code"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_category_form" model="ir.ui.view">
        <field name="name">assetflow.category.form</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <form string="Asset Category">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="status"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Asset Registry Views -->
    <record id="view_assetflow_asset_tree" model="ir.ui.view">
        <field name="name">assetflow.asset.tree</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <tree string="Asset Registry" decoration-info="state == 'available'" decoration-warning="state == 'maintenance'" decoration-danger="state == 'lost'" decoration-muted="state in ['retired', 'disposed']">
                <field name="tag"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="serial_no"/>
                <field name="location"/>
                <field name="condition"/>
                <field name="current_holder_id"/>
                <field name="is_shared" widget="boolean_toggle"/>
                <field name="state" widget="badge" decoration-success="state == 'available'" decoration-warning="state in ['allocated', 'reserved']" decoration-danger="state == 'lost'" decoration-info="state == 'maintenance'"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_asset_form" model="ir.ui.view">
        <field name="name">assetflow.asset.form</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <form string="Asset Registry">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="available,allocated,maintenance"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'zoom': true, 'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <label for="tag" string="Asset Tag"/>
                        <h1>
                            <field name="tag" readonly="1"/>
                        </h1>
                        <label for="name" string="Asset Name"/>
                        <h2>
                            <field name="name" placeholder="e.g. Dell Latitude 5420"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="category_id" options="{'no_create': True, 'no_open': False}"/>
                            <field name="serial_no"/>
                            <field name="location"/>
                            <field name="condition"/>
                        </group>
                        <group>
                            <field name="acquisition_date"/>
                            <field name="acquisition_cost"/>
                            <field name="is_shared" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <tab string="Custodian Info" name="custodian">
                            <group>
                                <field name="current_holder_id" readonly="1"/>
                                <field name="current_department_id" readonly="1"/>
                            </group>
                        </tab>
                        <tab string="Allocations &amp; Transfers" name="history">
                            <separator string="Allocation History"/>
                            <field name="allocation_ids" readonly="1">
                                <tree>
                                    <field name="employee_id"/>
                                    <field name="department_id"/>
                                    <field name="expected_return_date"/>
                                    <field name="actual_return_date"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </tab>
                        <tab string="Maintenance History" name="maintenance">
                            <field name="maintenance_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="technician_id"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </tab>
                        <tab string="Bookings" name="bookings" invisible="not is_shared">
                            <field name="booking_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="user_id"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </tab>
                        <tab string="Manuals &amp; Documents" name="documents">
                            <field name="document_ids" widget="many2many_binary"/>
                        </tab>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_assetflow_asset_kanban" model="ir.ui.view">
        <field name="name">assetflow.asset.kanban</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="id"/>
                <field name="tag"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="condition"/>
                <field name="current_holder_id"/>
                <field name="image"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <t t-if="record.image.raw_value">
                                <div class="o_kanban_image_fill_left d-none d-md-block" t-attf-style="background-image:url('#{kanban_image('assetflow.asset', 'image', record.id.raw_value)}')"/>
                            </t>
                            <t t-else="">
                                <div class="o_kanban_image_fill_left d-none d-md-block bg-light text-center align-middle py-4">
                                    <span class="text-muted text-uppercase fw-bold"><t t-esc="record.tag.value[:2]"/></span>
                                </div>
                            </t>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div>
                                    <span class="badge rounded-pill bg-light text-dark"><field name="tag"/></span>
                                    <span class="badge rounded-pill bg-light text-dark"><field name="category_id"/></span>
                                </div>
                                <div class="text-muted">
                                    Condition: <field name="condition"/>
                                </div>
                                <div class="text-muted" t-if="record.current_holder_id.raw_value">
                                    Held By: <field name="current_holder_id"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left"/>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="state" widget="label_selection" options="{'classes': {'available': 'success', 'allocated': 'warning', 'reserved': 'info', 'maintenance': 'warning', 'lost': 'danger', 'retired': 'default'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_assetflow_asset_search" model="ir.ui.view">
        <field name="name">assetflow.asset.search</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <search string="Search Assets">
                <field name="name" string="Asset Name/Tag/Serial" filter_domain="['|', '|', ('name', 'ilike', self), ('tag', 'ilike', self), ('serial_no', 'ilike', self)]"/>
                <field name="category_id"/>
                <field name="location"/>
                <field name="current_holder_id"/>
                <filter string="Available" name="available" domain="[('state', '=', 'available')]"/>
                <filter string="Allocated" name="allocated" domain="[('state', '=', 'allocated')]"/>
                <filter string="Under Maintenance" name="maintenance" domain="[('state', '=', 'maintenance')]"/>
                <filter string="Shared / Bookable" name="shared" domain="[('is_shared', '=', True)]"/>
                <filter string="Lost" name="lost" domain="[('state', '=', 'lost')]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Lifecycle Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Condition" name="group_by_condition" context="{'group_by': 'condition'}"/>
                    <filter string="Custodian" name="group_by_custodian" context="{'group_by': 'current_holder_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Reporting Pivot & Graph Views -->
    <record id="view_assetflow_asset_pivot" model="ir.ui.view">
        <field name="name">assetflow.asset.pivot</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <pivot string="Asset Analysis" sample="1">
                <field name="category_id" type="row"/>
                <field name="state" type="col"/>
                <field name="acquisition_cost" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_assetflow_asset_graph" model="ir.ui.view">
        <field name="name">assetflow.asset.graph</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <graph string="Asset Costs by Category" type="bar" sample="1">
                <field name="category_id"/>
                <field name="acquisition_cost" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Window Actions -->
    <record id="action_assetflow_asset_all" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">assetflow.asset</field>
        <field name="view_mode">kanban,tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_assetflow_asset_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first organization asset!
            </p>
            <p>
                Track laptops, desks, vehicles, meeting rooms, and other corporate resources in a centralized registry.
            </p>
        </field>
    </record>

    <record id="action_assetflow_category_all" model="ir.actions.act_window">
        <field name="name">Asset Categories</field>
        <field name="res_model">assetflow.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define an asset category (e.g. Electronics, Furniture).
            </p>
        </field>
    </record>
</odoo>
