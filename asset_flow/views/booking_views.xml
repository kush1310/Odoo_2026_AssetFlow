<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Resource Booking Views -->
    <record id="view_assetflow_booking_calendar" model="ir.ui.view">
        <field name="name">assetflow.booking.calendar</field>
        <field name="model">assetflow.booking</field>
        <field name="arch" type="xml">
            <calendar string="Resource Bookings" date_start="start_time" date_stop="end_time" color="asset_id" mode="week" quick_create="False">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="user_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_assetflow_booking_tree" model="ir.ui.view">
        <field name="name">assetflow.booking.tree</field>
        <field name="model">assetflow.booking</field>
        <field name="arch" type="xml">
            <tree string="Resource Bookings" decoration-info="state == 'upcoming'" decoration-success="state in ['ongoing', 'completed']" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="user_id"/>
                <field name="employee_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="state" widget="badge" decoration-info="state == 'upcoming'" decoration-success="state == 'ongoing'" decoration-muted="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_booking_form" model="ir.ui.view">
        <field name="name">assetflow.booking.form</field>
        <field name="model">assetflow.booking</field>
        <field name="arch" type="xml">
            <form string="Resource Booking">
                <header>
                    <button name="action_complete" string="Mark Completed" type="object" class="oe_highlight" invisible="state not in ['upcoming', 'ongoing']"/>
                    <button name="action_cancel" string="Cancel Booking" type="object" class="btn-secondary" invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="upcoming,ongoing,completed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Booking Purpose"/>
                        <h1>
                            <field name="name" placeholder="e.g. Weekly Team Alignment Meeting" readonly="state == 'cancelled'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="asset_id" options="{'no_create': True}" readonly="state == 'cancelled'"/>
                            <field name="user_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="start_time" readonly="state == 'cancelled'"/>
                            <field name="end_time" readonly="state == 'cancelled'"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_assetflow_booking_all" model="ir.actions.act_window">
        <field name="name">Resource Bookings</field>
        <field name="res_model">assetflow.booking</field>
        <field name="view_mode">calendar,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Book a shared resource.
            </p>
            <p>
                Schedule conference rooms, company vehicles, or shared electronics with calendar conflict checks.
            </p>
        </field>
    </record>
</odoo>
