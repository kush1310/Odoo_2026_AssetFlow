<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Asset Audit Cycle Tree View -->
    <record id="view_assetflow_audit_cycle_tree" model="ir.ui.view">
        <field name="name">assetflow.audit.cycle.tree</field>
        <field name="model">assetflow.audit.cycle</field>
        <field name="arch" type="xml">
            <tree string="Audit Cycles" decoration-info="state == 'active'" decoration-success="state == 'closed'">
                <field name="name"/>
                <field name="scope_department_id"/>
                <field name="scope_location"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge" decoration-info="state == 'active'" decoration-success="state == 'closed'"/>
            </tree>
        </field>
    </record>

    <!-- Asset Audit Cycle Form View -->
    <record id="view_assetflow_audit_cycle_form" model="ir.ui.view">
        <field name="name">assetflow.audit.cycle.form</field>
        <field name="model">assetflow.audit.cycle</field>
        <field name="arch" type="xml">
            <form string="Audit Cycle">
                <header>
                    <button name="action_start" string="Start Audit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_close" string="Close &amp; Apply Discrepancies" type="object" class="oe_highlight" groups="asset_flow.group_assetflow_manager" invisible="state != 'active'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Audit Cycle Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Q3 2026 IT Asset Audit" readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Audit Scope">
                            <field name="scope_department_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="scope_location" placeholder="e.g. Server Room B2" readonly="state != 'draft'"/>
                        </group>
                        <group string="Schedule &amp; Personnel">
                            <field name="start_date" readonly="state != 'draft'"/>
                            <field name="end_date" readonly="state == 'closed'"/>
                            <field name="auditor_ids" widget="many2many_tags" options="{'no_create': True}" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <tab string="Asset Verification Grid" name="verification_grid" invisible="state == 'draft'">
                            <field name="line_ids" readonly="state == 'closed'">
                                <tree editable="bottom" create="false" delete="false">
                                    <field name="asset_id" readonly="1"/>
                                    <field name="expected_holder_id" readonly="1"/>
                                    <field name="expected_location" readonly="1"/>
                                    <field name="status" widget="selection_badge" decoration-warning="status == 'damaged'" decoration-danger="status == 'missing'" decoration-success="status == 'verified'"/>
                                    <field name="notes" placeholder="Auditor notes..."/>
                                </tree>
                            </field>
                        </tab>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_assetflow_audit_cycle_all" model="ir.actions.act_window">
        <field name="name">Audit Cycles</field>
        <field name="res_model">assetflow.audit.cycle</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new audit cycle.
            </p>
            <p>
                Define an audit scope (department or physical location), assign auditors, and verify asset statuses in a structured cycle.
            </p>
        </field>
    </record>
</odoo>
